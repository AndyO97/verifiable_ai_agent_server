# ============================================================================
# OPENROUTER.AI CONFIGURATION (Recommended - Free LLM)
# ============================================================================

# Get free API key at: https://openrouter.ai/keys
# This is the primary LLM provider used in real_prompt_demo.py and real_agent_demo.py
OPENROUTER_API_KEY=sk-or-YOUR_API_KEY_HERE

# Optional: Override default model (default: arcee-ai/trinity-large-preview:free - FREE)
# Available free models: https://openrouter.ai/docs#models
OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free
# OPENROUTER_TEMPERATURE=0.7
# OPENROUTER_MAX_TOKENS=2000


# ============================================================================
# OLLAMA CONFIGURATION (Alternative - Local LLM)
# ============================================================================

# Only needed if running Ollama locally instead of OpenRouter
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=mistral
# OLLAMA_TEMPERATURE=0.7
# OLLAMA_MAX_TOKENS=2000


# ============================================================================
# STORAGE CONFIGURATION
# ============================================================================

# Local file storage (default)
LOCAL_STORAGE_BASE_PATH=./artifacts

# S3 (optional for production)
# S3_ENDPOINT_URL=https://s3.amazonaws.com
# S3_ACCESS_KEY_ID=your_access_key
# S3_SECRET_ACCESS_KEY=your_secret_key
# S3_BUCKET=verifiable-agent-logs
# S3_REGION=us-east-1


# ============================================================================
# DATABASE CONFIGURATION (optional - for production counter persistence)
# ============================================================================

# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_password
# POSTGRES_DATABASE=verifiable_agent


# ============================================================================
# OBSERVABILITY CONFIGURATION - Langfuse Integration (Required for full tracing)
# ============================================================================

# Langfuse setup instructions: See LANGFUSE_SETUP_GUIDE.md
# Get keys from your Langfuse instance at: http://localhost:3000 or https://cloud.langfuse.com
LANGFUSE_API_ENDPOINT=http://localhost:3000
LANGFUSE_PUBLIC_KEY=your_public_key_here
LANGFUSE_SECRET_KEY=your_secret_key_here

# OpenTelemetry (optional - for additional observability)
# OTEL_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=verifiable-ai-agent


# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# SERVER_HOST=0.0.0.0
# SERVER_PORT=8000
# DEBUG=false
